{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "references": [
    { "path": "core" },
    { "path": "cli" },
    { "path": "server" },
    { "path": "web" }
  ],
  "include": [],
  "exclude": ["node_modules"]
}
