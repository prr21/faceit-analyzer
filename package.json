{
  "name": "faceit",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["core", "cli", "server", "web"],
  "scripts": {
    "team": "tsx cli/team.ts",
    "player": "tsx cli/player.ts",
    "smurfs": "tsx cli/smurfs.ts",
    "match": "tsx cli/match.ts",
    "voice": "tsx cli/voice.ts",
    "dev:web": "npm run dev -w @faceit/web",
    "dev:server": "npm run dev -w @faceit/server",
    "build:web": "npm run build -w @faceit/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:core": "tsc --noEmit -p core/tsconfig.json",
    "typecheck:cli": "tsc --noEmit -p cli/tsconfig.json",
    "typecheck:server": "npm run typecheck -w @faceit/server",
    "typecheck:web": "npm run typecheck -w @faceit/web"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
