# FACEIT Open Data API key (https://developers.faceit.com/)
FACEIT_API_KEY=your_api_key_here

# AI-режим матч-анализа. Бесплатный ключ Groq: https://console.groq.com/keys
# Провайдер OpenAI-совместимый — сменить на OpenRouter/Gemini можно через BASE_URL+MODEL.
AI_API_KEY=your_groq_api_key_here
# AI_BASE_URL=https://api.groq.com/openai/v1   # по умолчанию Groq
# AI_MODEL=llama-3.3-70b-versatile             # по умолчанию

# Server
PORT=3000
HOST=localhost
CORS_ORIGIN=http://localhost:5173

# Web (vite читает root .env через envDir, переменные с префиксом VITE_)
# VITE_API_URL=http://localhost:3000   # переопределить proxy target
